{
    "name": "@tutors.plus/design-system",
    "version": "0.1.0-pilot.21",
    "description": "PLUS Design System for Figma Make",
    "main": "dist/index.js",
    "module": "dist/index.esm.js",
    "types": "dist/index.d.ts",
    "style": "dist/design-system.css",
    "sideEffects": [
        "*.css",
        "*.scss"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.esm.js",
            "require": "./dist/index.js",
            "default": "./dist/index.esm.js"
        },
        "./styles": {
            "import": "./dist/design-system.css",
            "require": "./dist/design-system.css"
        }
    },
    "files": [
        "dist",
        "guidelines"
    ],
    "scripts": {
        "build": "vite build",
        "prepublishOnly": "npm run build",
        "test": "vitest run"
    },
    "peerDependencies": {
        "bootstrap": ">=5.3.0",
        "react": ">=18.0.0",
        "react-bootstrap": ">=2.10.0",
        "react-dom": ">=18.0.0"
    },
    "dependencies": {
        "classnames": "^2.3.2",
        "highcharts": "^12.4.0",
        "highcharts-react-official": "^3.2.3",
        "prop-types": "^15.8.1"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.4.2",
        "@testing-library/react": "^14.2.1",
        "@vitejs/plugin-react": "^4.3.4",
        "bootstrap": "^5.3.3",
        "classnames": "^2.3.2",
        "jsdom": "^24.0.0",
        "react-bootstrap": "^2.10.10",
        "sass": "^1.77.8",
        "vite": "^6.0.0",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^1.3.1"
    },
    "keywords": [
        "plus",
        "design-system",
        "figma-make",
        "react",
        "components"
    ],
    "author": "PLUS Design Team",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/CMU-PLUS/plus-design-system"
    }
}