{
  "name": "plus-vibe-coding-starting-kit",
  "version": "1.0.0",
  "description": "Starter kit for PLUS design prototyping with Cursor agent",
  "main": "index.js",
  "scripts": {
    "build:css": "sass src/css/main.scss dist/css/main.css",
    "watch:css": "sass --watch src/css/main.scss:dist/css/main.css",
    "serve": "python3 -m http.server 8000",
    "test": "echo \"Error: no test specified\" && exit 1",
    "storybook": "storybook dev -p 6006 --config-dir sandbox/.storybook",
    "build-storybook": "storybook build --config-dir sandbox/.storybook -o sandbox/storybook-static"
  },
  "keywords": [
    "plus",
    "design-system",
    "prototyping",
    "cursor"
  ],
  "author": "PLUS Design Team",
  "license": "ISC",
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/html": "^8.6.14",
    "@storybook/html-vite": "^8.6.14",
    "sass": "^1.77.8",
    "storybook": "^8.6.14",
    "vite": "^7.2.2"
  }
}
