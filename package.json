{
  "name": "plus-vibe-coding-starting-kit",
  "version": "1.0.0",
  "description": "Starter kit for PLUS design prototyping with Cursor agent",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build:css": "sass --load-path=develop/tokens --load-path=legacy-ds/components new-ds/styles/main.scss dist/css/main.css",
    "watch:css": "sass --load-path=develop/tokens --load-path=legacy-ds/components --watch new-ds/styles/main.scss:dist/css/main.css",
    "watch:css:auto": "node scripts/watch-css.js",
    "dev": "npm run watch:css:auto & npm run serve",
    "serve": "python3 -m http.server ${PORT:-8000}",
    "test": "echo \"Error: no test specified\" && exit 1",
    "storybook": "storybook dev -p 6006 --config-dir .storybook",
    "build-storybook": "storybook build --config-dir .storybook -o storybook-static",
    "sync:tokens": "node scripts/sync-figma-tokens.js",
    "generate:tokens": "node scripts/generate-all-tokens.js",
    "dev:react": "vite",
    "build:react": "vite build",
    "preview:react": "vite preview"
  },
  "keywords": [
    "plus",
    "design-system",
    "prototyping",
    "cursor"
  ],
  "author": "PLUS Design Team",
  "license": "ISC",
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.15",
    "@storybook/addon-links": "^8.6.15",
    "@storybook/html": "^8.6.15",
    "@storybook/html-vite": "^8.6.15",
    "@storybook/react": "^8.6.15",
    "@storybook/react-vite": "^8.6.15",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "dotenv": "^16.4.5",
    "playwright": "^1.57.0",
    "sass": "^1.77.8",
    "vite": "~6.4.1",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@vitejs/plugin-react": "^5.1.1",
    "bootstrap": "^5.3.3",
    "highcharts": "^12.4.0",
    "highcharts-react-official": "^3.2.3",
    "react": "^19.2.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.1",
    "storybook": "^8.6.15",
    "typescript": "^5.9.3"
  }
}
