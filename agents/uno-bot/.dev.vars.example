# Example secrets file for local development with `wrangler dev`.
# Copy this to `.dev.vars` (gitignored) and fill in the real values.
#
# For production deploys, set each via `npx wrangler secret put <NAME>` instead;
# DO NOT use this file for production secrets. The full expected-secrets list
# also lives as a comment block in wrangler.toml — keep the two in sync.

# --- Slack ---
# api.slack.com/apps -> your app -> Basic Information -> "Signing Secret"
SLACK_SIGNING_SECRET=

# api.slack.com/apps -> your app -> OAuth & Permissions -> "Bot User OAuth Token" (starts xoxb-)
SLACK_BOT_TOKEN=

# Secret for the static Slack OAuth client (its client_id is the non-secret
# SLACK_MCP_CLIENT_ID in wrangler.toml [vars]). Powers the slack_search user token.
SLACK_MCP_CLIENT_SECRET=

# --- Model providers (which one runs is wrangler.toml MODEL_PROVIDER) ---
# Two lanes: "gemini" (default) and "vertex-claude". Both can run on the SAME
# Vertex service-account pair below; Claude bills to the GCP project. Set the
# service account (Vertex) — this is what production and Vertex-Claude use.
# RULE (2026-07-16, ADR-018): the Vertex SA is canonical and takes precedence
# whenever fully set (email + key + project id).
GEMINI_SA_EMAIL=
GEMINI_SA_PRIVATE_KEY=
# …OR, for the Gemini lane only, an AI Studio key — local-dev emergency
# fallback ONLY, never set on the Worker; it CANNOT reach Claude (only the
# Vertex SA path can) and only applies when the SA is not fully configured:
GEMINI_API_KEY=

# --- GitHub ---
# github.com/settings/tokens -> Generate new (classic) with `repo` scope, OR
# github.com/settings/personal-access-tokens with `Contents: Read` + `Actions: Read & Write`
# scoped to the target repo (BilLogic/plus-uno)
GITHUB_TOKEN=

# --- Notion ---
# Internal integration token, connected to the Roadmap board (notion_create / notion_update)
NOTION_API_KEY=

# --- Figma ---
# Read-scoped PAT — powers the proposal-card screenshot on prototype_scaffold
FIGMA_ACCESS_TOKEN=

# --- Supabase (uno-blueprint) ---
# Publishable/anon read key for blueprint_search (SUPABASE_URL is a [vars] entry)
SUPABASE_ANON_KEY=

# --- Gmail (email_send) ---
GMAIL_SENDER=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
