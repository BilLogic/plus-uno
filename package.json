{
  "name": "plus-vibe-coding-starting-kit",
  "version": "1.0.0",
  "description": "Starter kit for PLUS design prototyping with Cursor agent",
  "main": "index.js",
  "scripts": {
    "build:css": "sass --load-path=develop/tokens --load-path=design-system/components src/css/main.scss dist/css/main.css",
    "watch:css": "sass --load-path=develop/tokens --load-path=design-system/components --watch src/css/main.scss:dist/css/main.css",
    "watch:css:auto": "node scripts/watch-css.js",
    "dev": "npm run watch:css:auto & npm run serve",
    "serve": "python3 -m http.server 8000",
    "test": "echo \"Error: no test specified\" && exit 1",
    "storybook": "storybook dev -p 6006 --config-dir .storybook",
    "build-storybook": "storybook build --config-dir .storybook -o storybook-static",
    "sync:tokens": "node scripts/sync-figma-tokens.js",
    "generate:tokens": "node scripts/generate-all-tokens.js"
  },
  "keywords": [
    "plus",
    "design-system",
    "prototyping",
    "cursor"
  ],
  "author": "PLUS Design Team",
  "license": "ISC",
  "devDependencies": {
    "@storybook/addon-links": "^10.1.0",
    "@storybook/html": "^10.1.0",
    "@storybook/html-vite": "^10.1.0",
    "dotenv": "^16.4.5",
    "sass": "^1.77.8",
    "storybook": "^10.1.0",
    "vite": "^7.2.2",
    "@storybook/addon-docs": "^10.1.0"
  }
}
