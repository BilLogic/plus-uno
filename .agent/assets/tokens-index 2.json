{
  "schema_version": "1.0",
  "updated_for_branch": "main",
  "token_scss_files": [
    "design-system/src/tokens/_colors.scss",
    "design-system/src/tokens/_spacing_semantics.scss",
    "design-system/src/tokens/_fonts.scss",
    "design-system/src/tokens/_elevation.scss",
    "design-system/src/tokens/_layout.scss",
    "design-system/src/tokens/_primitives.scss"
  ],
  "token_source_json_glob": "design-system/src/tokens/source/*.json",
  "sync_scripts": [
    "scripts/sync-figma-tokens.js",
    "scripts/generate-all-tokens.js"
  ],
  "npm_scripts": [
    "npm run sync:tokens",
    "npm run generate:tokens"
  ],
  "ci_workflows": [
    ".github/workflows/sync-figma-tokens.yml"
  ],
  "required_env_vars": [
    "FIGMA_FILE_KEY",
    "FIGMA_ACCESS_TOKEN"
  ]
}
